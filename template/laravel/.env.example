# ═══════════════════════════════════════════════════════════════
#  Laravel Docker Dev - Environment Configuration
#  Copy this file to .env and adjust values as needed
# ═══════════════════════════════════════════════════════════════

# ── Project Identity ──────────────────────────────────────────
CONTAINER_NAME=my_laravel_app
DOMAIN_DEV=my-app.localhost

# ── Docker Images ─────────────────────────────────────────────
NGINX_IMAGE=nginx:stable-alpine

# ── PHP Version ───────────────────────────────────────────────
PHP_VERSION=8.4

# ── PHP Configuration ─────────────────────────────────────────
PHP_MEMORY_LIMIT=512M
PHP_POST_MAX_SIZE=128M
PHP_MAX_EXECUTION_TIME=300
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_MAX_INPUT_TIME=300
PHP_MAX_INPUT_VARS=3000

# ── Nginx Configuration ───────────────────────────────────────
NGINX_CLIENT_MAX_BODY_SIZE=128M
NGINX_CLIENT_BODY_TIMEOUT=300s
NGINX_CLIENT_HEADER_TIMEOUT=300s
NGINX_PROXY_TIMEOUT=300s
NGINX_FASTCGI_READ_TIMEOUT=300s
NGINX_FASTCGI_SEND_TIMEOUT=300s

# ── Redis Configuration ───────────────────────────────────────
REDIS_PASSWORD=nginx:stable-alpine

# ── User/Group IDs (match your host user to avoid permission issues) ──
UID=1000
GID=1000

# ── Xdebug ────────────────────────────────────────────────────
# off      → disabled (fastest, use in normal dev)
# debug    → step debugging with IDE
# develop  → better var_dump / error reporting
# coverage → code coverage for tests
# profile  → performance profiling
XDEBUG_MODE=off
XDEBUG_HOST=host.docker.internal
XDEBUG_IDE_KEY=DOCKER
XDEBUG_PORT=9003

# ── Mailpit (local email testing) ─────────────────────────────
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025
